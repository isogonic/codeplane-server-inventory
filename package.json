{
  "name": "@isogonic/codeplane-server-inventory",
  "version": "0.5.5",
  "description": "Codeplane MCP server for SSH server inventory with encrypted secrets. Lets Codeplane agents answer 'audit all <group> servers' without manual credential input.",
  "type": "module",
  "bin": {
    "server-inventory-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isogonic/codeplane-server-inventory.git",
    "directory": "."
  },
  "homepage": "https://github.com/isogonic/codeplane-server-inventory#readme",
  "bugs": {
    "url": "https://github.com/isogonic/codeplane-server-inventory/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "npm run build --silent && node scripts/smoke.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test": "npm run build --silent && npm run test:unit --silent && node scripts/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codeplane",
    "mcp",
    "model-context-protocol",
    "server-inventory",
    "ssh",
    "devops"
  ],
  "license": "MIT"
}
